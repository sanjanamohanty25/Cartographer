# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/agent_hocon_reference.md

{
    # Optional metadata describing this agent network
    "metadata": {
        "description": "Simple agent network with one agent and a skill middleware that progressively loads a skill from a local directory.",
        "tags": ["example", "skills"],
        "sample_queries": [
            "My name is Jack. What is my job?",
            "I am Bob. Where should I work?",
            "I'm Jane. How much should I get paid per year?"
        ]
    },

    # Load the shared LLM configuration from a single source of truth.
    # This allows users to change the model in one file rather than
    # modifying the configuration for each agent network.
    # Note that the file path here is relative to the root level of the repo.
    include "config/llm_config.hocon",

    "tools": [
        # This first agent definition is regarded as the "Front Man", which
        # does all the talking to the outside world/client.
        #
        # Some disqualifications from being a front man:
        #   1) Cannot use a CodedTool "class" definition
        #   2) Cannot use a Tool "toolbox" definition
        #
        # Besides the first agent being the front man, these tool definitions
        # do not have to be in any particular order. How they are linked and
        # call each other is defined within their own specs.
        # This could be a graph, potentially even with cycles.
        {
            "name": "name_assistant",

            # Note that there are no parameters defined for this guy's "function" key.
            # This is the primary way to identify this tool as a front-man,
            # distinguishing it from the rest of the tools.

            "function": {

                # The description acts as an initial prompt.
                "description": """
I can help with name-related inquiries.
"""
            },

            "instructions": """
You are a name assistant that provides career information based on user's name.
""",
            "middleware": [
                {
                    # This middleware implements the Agent Skills specification:
                    # https://agentskills.io/specification
                    #
                    # It follows the progressive disclosure pattern:
                    # skill metadata is loaded first, and full content or additional resources
                    # are retrieved only when requested.
                    #
                    # The middleware provides tools to load skill content from the local
                    # filesystem or remote URLs:
                    # - get_full_skill_content: loads the full contents of SKILL.md
                    # - load_skill_resource_local: loads additional files from the skill's local directory
                    # - load_skill_resource_remote: loads additional files from the skill's remote URL root
                    "class": "middleware.agent_skills_middleware.AgentSkillsMiddleware",

                    "args": {
                        # List of skill directories. Each directory must contain a SKILL.md file.
                        # Sources can be either local file paths or URLs. 
                        # For local sources, use a path relative to the script's working directory
                        # or provide an absolute path.
                        #
                        # ⚠️ Security note:
                        # Be cautious when using skills from the internet. They may contain malicious
                        # scripts or reference tools and resources that are not available in your
                        # environment. Always review the skill contents carefully before using it
                        # in your agent.
                        #
                        # Note: The following skills are intended for testing only.
                        # Personal or sensitive information should not be included in agent skills.
                        "skill_sources": ["skills/tests/job_guessing"],

                        # Control how skill content is managed in the conversation context.
                        # 
                        # When set to true:
                        #   - Skill content remains in chat history after loading
                        #   - Agent can reference and combine information from multiple skills simultaneously
                        #   - Higher token usage but fewer redundant tool calls
                        #   - Best for: Complex tasks requiring cross-referencing multiple skills
                        # 
                        # When set to false (recommended):
                        #   - Skill content removed from chat history after use
                        #   - Saves significant tokens in long conversations
                        #   - Agent may re-load skills if needed
                        #   - Best for: Most use cases, especially token-constrained environments
                        # 
                        # Trade-off: Token efficiency vs. cross-skill synthesis capability
                        # Default: false
                        "keep_skill_in_context": true
                    }
                },
            ],
        }
    ]
}
