{
    include "registries/aaosa_basic.hocon",

    "metadata": {
        "description": "An example book recommendation network that uses multiple LLM backends, including Anthropic Opus, Sonnet, and Haiku models, demonstrating per-agent llm_config customization.",
        "tags": ["basic", "example", "AAOSA", "llm_config", "anthropic"],
        "sample_queries": [
            "Suggest me a good book to read.",
            "I want something thrilling and suspenseful.",
            "What's a good science fiction book for beginners?",
            "I'd like a non-fiction book about history.",
        ]
    },

    "tools": [
        {
            "name": "BookRecommender",

            "function": {
                "description": """
I can recommend books across different genres.
Tell me what kind of book you're looking for.
"""
            },

            "llm_config": {
                "model_name": "claude-opus"
            },

            "instructions": """
You are a book recommender. Route each request to the matching genre expert(s):
fiction, non-fiction, mystery/thriller, or science fiction. If the request
spans multiple genres, consult all relevant experts and combine their
recommendations. If none match, call the closest expert.
Then call QuickSummary for a one-line summary of each recommended book and
include those summaries in your final response.
Keep the response concise and professional. Do not use emoticons.
""" ${aaosa_instructions},
            "tools": ["FictionExpert", "NonFictionExpert", "MysteryExpert", "SciFiExpert", "QuickSummary"]
        },
        {
            "name": "FictionExpert",
            "function": ${aaosa_call}{
                "description": "Recommends fiction and literary novels."
            },
            "llm_config": {
                "model_name": "claude-sonnet"
            },
            "instructions": """
Your name is FictionExpert. You recommend fiction and literary novels.
Recommend one book with a brief reason why it fits the request.
""" ${aaosa_instructions}
        },
        {
            "name": "NonFictionExpert",
            "function": ${aaosa_call}{
                "description": "Recommends non-fiction books."
            },
            "llm_config": {
                "model_name": "claude-sonnet"
            },
            "instructions": """
Your name is NonFictionExpert. You recommend non-fiction books.
Recommend one book with a brief reason why it fits the request.
""" ${aaosa_instructions}
        },
        {
            "name": "MysteryExpert",
            "function": ${aaosa_call}{
                "description": "Recommends mystery and thriller books."
            },
            "llm_config": {
                "model_name": "claude-sonnet"
            },
            "instructions": """
Your name is MysteryExpert. You recommend mystery and thriller books.
Recommend one book with a brief reason why it fits the request.
""" ${aaosa_instructions}
        },
        {
            "name": "SciFiExpert",
            "function": ${aaosa_call}{
                "description": "Recommends science fiction books."
            },
            "llm_config": {
                "model_name": "claude-sonnet"
            },
            "instructions": """
Your name is SciFiExpert. You recommend science fiction books.
Recommend one book with a brief reason why it fits the request.
""" ${aaosa_instructions}
        },
        {
            "name": "QuickSummary",
            "function": ${aaosa_call}{
                "description": "Provides a brief one-line summary of a recommended book."
            },
            "llm_config": {
                "model_name": "claude-haiku"
            },
            "instructions": """
Your name is QuickSummary. You provide a brief one-line summary
of a recommended book when asked.
""" ${aaosa_instructions}
        }
    ]
}
