# Persistent Memory (Mem0) — example agent network using the Mem0 cloud backend.
#
# Same ``PersistentMemoryMiddleware`` as ``persistent_memory_local.hocon``, but the
# storage block is swapped for the Mem0 cloud backend. There are no local
# files: every read/write goes against the Mem0 API and each topic is one
# Mem0 memory entry, scoped by Mem0's first-class ``app_id`` (the agent
# network) and ``agent_id`` (the agent name) fields, with the topic name
# carried in ``metadata.topic``. For the file-backed variant, see
# ``persistent_memory_local.hocon``.
#
# Class path: middleware.persistent_memory.persistent_memory_middleware.PersistentMemoryMiddleware
#
# Prerequisites:
#   1. ``pip install "mem0ai>=2.0.2,<3.0"`` (not in the base ``requirements.txt``).
#   2. Set ``MEM0_API_KEY`` in your environment. Get a key at
#      https://app.mem0.ai/. The store reads the key on first use and raises
#      ``mem0.exceptions.ConfigurationError`` if it is missing; subsequent
#      calls reuse the cached client.
#   3. Keep ``"sly_data": true`` in the middleware ``args`` below. The
#      framework injects per-request ``sly_data`` so the store can scope
#      memories to the calling user via ``sly_data["user_id"]``.
#
# Per-user scoping:
#   Mem0 memories are partitioned by ``user_id``. ``Mem0Store`` resolves
#   the user ID in this order:
#     1. ``sly_data["user_id"]`` — the per-request value the framework injects.
#     2. ``MEM0_DEFAULT_USER_ID`` env var (plain string) —
#        a server-wide default useful for local testing.
#     3. ``"default_user"`` — fallback when neither is provided.
#   This is the key practical difference from the file-backed backends:
#   different users see different memory, even when they share the same
#   ``(network, agent)`` namespace.
#
# Lifecycle: write-per-call, same as the file-backed backends. Each tool
# call resolves to a single Mem0 ``add``/``update``/``delete`` call,
# guarded by a per-topic ``asyncio.Lock`` (different topics on the same
# agent can write in parallel; same-topic writes serialize). Summarization
# is off by default; enable it by adding the ``summarization`` block below.

{
    include "config/llm_config.hocon",

    "metadata": {
        "description": "Cloud-backed long-term memory (Mem0). Remembers facts you share across sessions and scopes them per user.",
        "tags": ["memory", "long-term-memory", "middleware", "mem0", "cloud"],
        "sample_queries": [
            # Same first-run flow as ``persistent_memory_local`` so the two examples are
            # easy to compare. With Mem0 these facts land in the cloud, scoped
            # to the calling user_id.
            "Hi, my name is Mike and I work in Sales.",
            "Remember that I prefer email communication over chat.",
            "Also note that I have moved to the Engineering department.",
            "What do you know about me?",
            "List everything you remember about me.",
            "Forget my communication preference.",
        ]
    },

    "tools": [
        {
            "name": "MemoryAssistant",
            "function": {
                "description": "A conversational assistant that remembers facts about you across sessions, backed by the Mem0 cloud."
            },
            "instructions": """
You are a helpful assistant that remembers facts the user shares about themselves —
names, roles, preferences, relationships, and personal details.

Save each fact as a topic/content pair. The topic is the person's name, lower-cased
and underscore-separated ("michael_brown", "tom"); every fact about that person
lives under their topic.

If memory has nothing on what the user is asking about, say so and ask them to
confirm or share the information — do not guess.
""",
            "tools": [],
            "middleware": [
                {
                    "class": "middleware.persistent_memory.persistent_memory_middleware.PersistentMemoryMiddleware",
                    "args": {
                        # Framework auto-injection.
                        #   ``origin_str``: parsed by the middleware to derive
                        #                   the (network, agent) namespace.
                        #   ``sly_data``:   per-request data dict; forwarded to
                        #                   ``Mem0Store`` so it can read
                        #                   ``sly_data["user_id"]`` for per-user
                        #                   memory scoping. REQUIRED for Mem0.
                        "origin_str": true,
                        "sly_data":   true,
                        # All memory settings live under a single ``memory_config`` block with three sub-keys.
                        "memory_config": {
                            # Mem0 cloud backend.
                            # Authentication uses the ``MEM0_API_KEY`` env var.
                            "storage": {
                                "backend": "mem0"
                            },
                            # Summarizer configuration. Optional — omit the whole ``summarization`` block to
                            # leave summarization off (the default).
                            #   ``max_topic_size``:  character threshold past which topics are summarized inline.
                            #   ``model``:           OpenAI model used by the summarizer; failures keep the original.
                            #   ``personalization``: optional sentence appended to the summarizer prompt.
                            "summarization": {
                                "max_topic_size":  1000,
                                "model":           "gpt-5.4-mini",
                                "personalization": ""  # optional, e.g. "Write summaries in a warm, concise tone."
                            },
                            # Which operations the LLM may use. Leave empty to allow all six.
                            # Useful restrictions:
                            #   Read-only agent:    ["read", "search", "list"]
                            #   Append-only agent:  ["read", "append", "search", "list"]
                            "enabled_operations": ["create", "read", "append", "delete", "search", "list"]
                        }
                    }
                }
            ]
        }
    ]
}
