{
    include "registries/aaosa.hocon",

 
    "metadata": {
        "description": "Multi-agent system that mimics the intranet of a major corporation. Allows you to interact with and get information from various departments such as IT, Finance, Legal, HR, and Procurement. The top-level agent receives a question and, in coordination with down-chain agents, provides comprehensive answers.",
        "tags": ["AAOSA", "industry"],
        "sample_queries": [
            "I recently got married",
            "How do I check my pay stub?",
        ]
    },

    # Load the shared LLM configuration from a single source of truth.
    # This allows users to change the model in one file rather than
    # modifying the configuration for each agent network.
    # Note that the file path here is relative to the root level of the repo.
    include "config/llm_config.hocon",

    "tools": [
        # This first agent definition is regarded as the "Front Man", which
        # does all the talking to the outside world/client.
        #
        # Some disqualifications from being a front man:
        #   1) Cannot use a CodedTool "class" definition
        #   2) Cannot use a Tool "toolbox" definition
        #
        # Besides the first agent being the front man, these tool definitions
        # do not have to be in any particular order. How they are linked and
        # call each other is defined within their own specs.
        # This could be a graph, potentially even with cycles.
        {
            "name": "main_search_box",

            "function": {

                # The description acts as an initial prompt. 

                "description": "I can help you with your intranet needs."
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "description": """
An employee inquiry about company intranet resources, internal documents, policies, or services.
"""
                        },
                    },
                    "required": ["query"]
                }
            },
            "instructions": """
You are the top-level agent responsible for handling all inquiries.
When interacting with the user, act as the single point of interaction. No need to mention the other tools or agents.
If there are any requirements that need user input, ask them one at a time, with clear examples of the choices available.
            """ ${aaosa_instructions},
            "tools": ["IT_agent", "Finance_agent", "Procurement_agent", "Legal_agent", "HR_agent"]
        },
        {
            "name": "IT_agent",
            "function": ${aaosa_call}{
                "description": "Handles all IT-related inquiries including technology support and system access."
            },
            "instructions": """
You are responsible for IT-related inquiries.
            """ ${aaosa_instructions},
            "tools": ["Security_agent", "Networking_agent"]
        },
        {
            "name": "Security_agent",
            "function": ${aaosa_call}{
                "description": "Handles security-related tasks including system protection, cybersecurity, and data security."
            },
            "instructions": """
Handles security-related tasks, including system protection, cybersecurity, and data security.
            """,
        },
        {
            "name": "Networking_agent",
            "function": ${aaosa_call}{
                "description": "Handles network-related tasks including setup, maintenance, and troubleshooting."
            },
            "instructions": """
Handles network-related tasks, including network setup, maintenance, and troubleshooting.
            """,
        },
        {
            "name": "Finance_agent",
            "function": ${aaosa_call}{
                "description": "Handles finance-related inquiries including budgeting, accounting, and financial reporting."
            },
            "instructions": """
Handles finance-related inquiries, including budgeting, accounting, and financial reporting.
            """ ${aaosa_instructions},
            "tools": ["Budgeting_agent", "Accounting_agent", "Financial_reporting_agent"]
        },
        {
            "name": "Budgeting_agent",
            "function": ${aaosa_call}{
                "description": "Handles budgeting tasks including budget planning, allocation, and tracking."
            },
            "instructions": """
Handles budgeting tasks, including budget planning, allocation, and tracking.
            """,
        },
        {
            "name": "Accounting_agent",
            "function": ${aaosa_call}{
                "description": "Handles accounting tasks including bookkeeping, financial records, and audits."
            },
            "instructions": """
Handles accounting tasks, including bookkeeping, financial records, and audits.
            """,
        },
        {
            "name": "Financial_reporting_agent",
            "function": ${aaosa_call}{
                "description": "Handles financial reporting including preparing statements, regulatory reporting, and analysis."
            },
            "instructions": """
Handles financial reporting tasks, including preparing financial statements, regulatory reporting, and performance analysis.
            """,
        },
        {
            "name": "Procurement_agent",
            "function": ${aaosa_call}{
                "description": "Handles procurement-related tasks including sourcing, purchasing, and vendor management."
            },
            "instructions": """
Handles procurement-related tasks.
            """ ${aaosa_instructions},
            "tools": ["Purchasing_agent", "Vendor_management_agent", "Contract_negotiation_agent"]
        },
        {
            "name": "Purchasing_agent",
            "function": ${aaosa_call}{
                "description": "Handles purchasing-related tasks including ordering, supply management, and procurement."
            },
            "instructions": """
Handles purchasing-related tasks, including ordering, supply management, and procurement processes.
            """,
        },
        {
            "name": "Vendor_management_agent",
            "function": ${aaosa_call}{
                "description": "Handles vendor management including selection, performance monitoring, and relationships."
            },
            "instructions": """
Handles vendor management tasks, including vendor selection, performance monitoring, and relationship management.
            """,
        },
        {
            "name": "Contract_negotiation_agent",
            "function": ${aaosa_call}{
                "description": "Handles contract negotiation including drafting, reviewing, and finalizing procurement contracts."
            },
            "instructions": """
Handles contract negotiation tasks, including drafting, reviewing, and finalizing procurement contracts.
            """,
        },
        {
            "name": "Legal_agent",
            "function": ${aaosa_call}{
                "description": "Handles legal-related inquiries including contracts, compliance, and legal advice."
            },
            "instructions": """
Handles legal-related inquiries.
            """ ${aaosa_instructions},
            "tools": ["Contracts_agent", "Compliance_agent", "Legal_advice_agent"]
        },
        {
            "name": "Contracts_agent",
            "function": ${aaosa_call}{
                "description": "Handles contract-related tasks including drafting, reviewing, and enforcing legal agreements."
            },
            "instructions": """
Handles contract-related tasks, including drafting, reviewing, and enforcing legal agreements.
            """,
        },
        {
            "name": "Compliance_agent",
            "function": ${aaosa_call}{
                "description": "Handles compliance-related tasks including adherence to laws, regulations, and internal policies."
            },
            "instructions": """
Handles compliance-related tasks, including ensuring adherence to laws, regulations, and internal policies.
            """,
        },
        {
            "name": "Legal_advice_agent",
            "function": ${aaosa_call}{
                "description": "Provides legal counsel, risk assessment, and legal strategy guidance."
            },
            "instructions": """
Handles legal advice tasks, including providing legal counsel, risk assessment, and legal strategy.
            """,
        },
        {
            "name": "HR_agent",
            "function": ${aaosa_call}{
                "description": "Handles HR-related inquiries including benefits, payroll, and employee relations."
            },
            "instructions": """
You are responsible for HR-related inquiries.
            """ ${aaosa_instructions},
            "tools": ["Benefits_agent", "Payroll_agent"]
        },
        {
            "name": "Benefits_agent",
            "function": ${aaosa_call}{
                "description": "Handles benefits-related tasks including employee benefits, health insurance, and retirement plans."
            },
            "instructions": """
Handles benefits-related tasks, including employee benefits, health insurance, and retirement plans.
            """,
        },
        {
            "name": "Payroll_agent",
            "function": ${aaosa_call}{
                "description": "Handles payroll-related tasks including salary processing, tax deductions, and pay slips."
            },
            "instructions": """
Handles payroll-related tasks, including salary processing, tax deductions, and pay slips.
            """,
        }
    ]
}
