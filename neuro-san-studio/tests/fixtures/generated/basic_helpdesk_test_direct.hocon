# This file defines everything necessary for a data-driven test.
# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/test_case_hocon_reference.md

# Fixture test for basic_helpdesk agent network generated by Agent Network Designer (AND).
# Direct mode: runs in-process with use_direct=true, no server required.
# Single run (success_ratio = "1/1").
{
    # Describes what agent to test against.
    "agent": "generated/basic_helpdesk",

    # Connect to the agent directly (no server required)
    "connections": ["direct"],

    # Timeout for the entire test (5 minutes)
    "timeout_in_seconds": 300,

    # 5 concurrent iterations via ThreadPoolExecutor.
    # All 5 must pass. Adjust as needed (e.g., "1/1" for a quick single check,
    # "3/5" to allow some tolerance, "10/10" for heavier load).
    "success_ratio": "1/1",

    # Interactions are a series of dictionaries with request elements paired with
    # descriptions of response checks.
    "interactions": [
        {
            # Technical support query - should route to technical_support agent
            "text": "My internet keeps dropping every few minutes, can you help?",

            # The response block treats how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # Keywords says we are going to look for exact matches for each
                    # element in a list of strings. All elements need to show up
                    # in order to pass.
                    "keywords": [
                        "Ethernet",
                        "modem",
                        "router",
                        "Wi",
                        "devices"
                    ],

                    # Gist says we are going to ask an LLM about how the response
                    # matches up to our description of acceptance criteria.
                    # Each component of the list needs to pass muster in order to pass.
                    "gist": [
                        "The response was routed to technical support (not billing) and provides structured connectivity troubleshooting.",
                        "The response asks whether the issue affects all devices or just one device.",
                        "The response identifies this as a technical or connectivity issue, not a billing issue.",
                        "The response suggests an Ethernet isolation test to determine if the problem is Wi-Fi specific or affects wired connections too."
                    ]
                }
            }
        }
    ]
}
